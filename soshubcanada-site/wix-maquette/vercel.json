{
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/services", "destination": "/services.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/employeurs", "destination": "/employeurs.html" },
    { "source": "/a-propos", "destination": "/a-propos.html" },
    { "source": "/book-online", "destination": "/book-online.html" },
    { "source": "/confidentialite", "destination": "/confidentialite.html" },
    { "source": "/conditions", "destination": "/conditions.html" },
    { "source": "/blog", "destination": "/blog.html" }
  ],
  "redirects": [
    {
      "source": "/privacy",
      "destination": "/confidentialite",
      "permanent": true
    },
    {
      "source": "/politique-confidentialite",
      "destination": "/confidentialite",
      "permanent": true
    },
    {
      "source": "/cgu",
      "destination": "/conditions",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://www.clarity.ms https://connect.facebook.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https://*.unsplash.com https://images.unsplash.com https://www.clarity.ms https://www.facebook.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://soshubca.vercel.app https://www.google-analytics.com https://api.emailjs.com https://www.clarity.ms https://region1.google-analytics.com; frame-src https://soshubca.vercel.app https://www.google.com; object-src 'none'; base-uri 'self'; form-action 'self' https://soshubca.vercel.app; upgrade-insecure-requests" }
      ]
    },
    {
      "source": "/(.*)\\.(jpg|jpeg|png|gif|svg|webp|ico|woff|woff2|ttf|eot)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(js|css)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
